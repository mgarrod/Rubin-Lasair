# Copy this file to ".env" and fill in your values.
#   cp .env.example .env
# The monitor reads .env automatically on startup.

# Your Lasair filter topic names, comma-separated. Each topic name is shown on
# that filter's detail page in Lasair — it looks like 'lasair_<id><name>'.
# Add as many as you have streaming filters.
LASAIR_TOPICS=lasair_2CVsInOutburst, lasair_3PulsatingVariables

# Identifies you to Kafka. Reuse the same value to resume where you left off;
# change it to replay the ~7-day backlog. Each topic gets this plus a suffix so
# their offsets are tracked separately.
LASAIR_GROUP_ID=moeller-monitor-1

# Usually leave these at the defaults.
# LASAIR_KAFKA=lasair-lsst-kafka.lsst.ac.uk:9092
# MONITOR_PORT=5001
